# --- Astrology Times backend env vars ---
# Copy this file to `.env` and fill in real values BEFORE deploying.
# DO NOT commit `.env` to git.

# MongoDB Atlas connection string (free tier works fine)
# Example: mongodb+srv://user:pass@cluster0.xxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://astrology_admin:Astro2026Taiga@cluster0.wrpacye.mongodb.net/astrology_times?retryWrites=true&w=majority

# Database name (any name you want; will be auto-created)
DB_NAME=astrology_times

# Long random string used to sign JWTs. Generate with:  openssl rand -hex 32
JWT_SECRET=astrology_times_secret_key_2026

# Universal LLM key from Emergent (Profile → Universal Key in your Emergent dashboard)
# Used for AI Kundli, AI Horoscope, AI Session Reports.
EMERGENT_LLM_KEY=sk-emergent-761Bf0463720eC7A9F

# Razorpay credentials (from https://dashboard.razorpay.com/app/keys)
# In test mode they start with rzp_test_; switch to rzp_live_ when you go live.
RAZORPAY_KEY_ID=rzp_test_SdqbVirWX69BIs
RAZORPAY_KEY_SECRET=rs14CtQumsAeeGC2r0gTucqM

# Admin login (used at /admin in the frontend)
ADMIN_EMAIL=admin@astrologytimes.co.in
ADMIN_PASSWORD=admin@1234

# Comma-separated list of allowed frontend origins, or * for any.
# Example for prod: https://astrologytimes.co.in,https://www.astrologytimes.co.in
CORS_ORIGINS=*
